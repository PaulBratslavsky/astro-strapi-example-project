---
import StrapiImage from "../../components/StrapiImage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

import type { CollectionEntry } from "astro:content";

type Item = CollectionEntry<"strapiWorkshops">;

export async function getStaticPaths() {
  const collection = await getCollection("strapiWorkshops");
  return collection.map((item) => ({
    params: { slug: item.data.slug },
    props: item.data,
  }));
}

const { props } = Astro;
const { title, description, instructor, skillLevel, duration, date, price, coverImage, learningOutcomes } = props;

const levelConfig: Record<string, { label: string; color: string }> = {
  beginner: { label: "Beginner", color: "bg-green-100 text-green-700" },
  intermediate: { label: "Intermediate", color: "bg-amber-100 text-amber-700" },
  advanced: { label: "Advanced", color: "bg-red-100 text-red-700" },
};

const level = skillLevel ? levelConfig[skillLevel] : null;

function formatPrice(p: number | null | undefined) {
  if (p === null || p === undefined) return null;
  if (p === 0) return "Free";
  return `$${p.toFixed(2)}`;
}

function formatDate(dateStr: string | null | undefined) {
  if (!dateStr) return null;
  const d = new Date(dateStr);
  return {
    full: d.toLocaleDateString("en-US", { weekday: "long", year: "numeric", month: "long", day: "numeric" }),
    time: d.toLocaleString("en-US", { hour: "numeric", minute: "2-digit", hour12: true }),
  };
}

const priceLabel = formatPrice(price);
const eventDate = formatDate(date);
---

<BaseLayout>
  <section class="mx-auto max-w-3xl px-6 py-16">
    <a href="/workshops" class="inline-flex items-center gap-1 text-sm text-muted hover:text-primary-600 transition">
      &larr; Back to Workshops
    </a>

    {coverImage && (
      <div class="mt-6 overflow-hidden rounded-2xl">
        <StrapiImage class="w-full aspect-[16/9] object-cover" src={coverImage.url} alt={coverImage.alternativeText || ""} height={600} width={1200} />
      </div>
    )}

    <div class="mt-8 flex flex-wrap items-center gap-3">
      {level && <span class={`rounded-full px-3 py-1 text-xs font-semibold ${level.color}`}>{level.label}</span>}
      {priceLabel && <span class={`rounded-full px-3 py-1 text-xs font-semibold ${price === 0 ? 'bg-green-100 text-green-700' : 'bg-primary-50 text-primary-700'}`}>{priceLabel}</span>}
    </div>

    <h1 class="mt-4 text-3xl font-bold tracking-tight text-secondary font-heading sm:text-4xl">{title}</h1>
    {instructor && <p class="mt-2 text-muted">Taught by <span class="font-medium text-secondary">{instructor}</span></p>}
    <p class="mt-6 text-muted leading-relaxed">{description}</p>

    <div class="mt-8 flex flex-wrap gap-6 rounded-xl border border-border bg-surface-raised p-5">
      {eventDate && (
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-primary-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
          <div>
            <p class="text-sm font-semibold text-secondary">{eventDate.full}</p>
            <p class="text-sm text-muted">{eventDate.time}</p>
          </div>
        </div>
      )}
      {duration && (
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-primary-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <p class="text-sm font-semibold text-secondary">{duration}</p>
        </div>
      )}
      {priceLabel && (
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-primary-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <p class={`text-sm font-semibold ${price === 0 ? 'text-green-700' : 'text-secondary'}`}>{priceLabel}</p>
        </div>
      )}
    </div>

    {learningOutcomes && (
      <div class="mt-10">
        <h2 class="text-xl font-bold text-secondary font-heading">What You'll Learn</h2>
        <div class="mt-4 prose prose-neutral max-w-none text-muted leading-relaxed
          [&_ul]:space-y-2 [&_ul]:list-none [&_ul]:pl-0
          [&_li]:flex [&_li]:items-start [&_li]:gap-3
          [&_li]:before:content-['✓'] [&_li]:before:text-primary-600 [&_li]:before:font-bold [&_li]:before:shrink-0">
          <Fragment set:html={learningOutcomes} />
        </div>
      </div>
    )}
  </section>
</BaseLayout>
