---
import StrapiImage from "../../components/StrapiImage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Markdown from "../../components/blocks/Markdown.astro";
import BlockRenderer from "../../components/blocks/BlockRenderer.astro";
import { getCollection } from 'astro:content';

import type { CollectionEntry } from "astro:content";

type Post = CollectionEntry<"strapiPosts">;

type CollectionArticle = {
  params: { slug: string };
  props: Post;
};

export async function getStaticPaths() {
  const collection = await getCollection('strapiPosts');

  function createStaticPaths(articles: Post[]) {
    return articles.map(article => ({
      params: { slug: article.data.slug },
      props: article.data
    }));
  }

  return createStaticPaths(collection);
}

const { props } = Astro;
const { featuredImage, author, contentTags, blocks, title, content } = props;
---

<BaseLayout>
  <article>
    {featuredImage && (
      <div class="mx-auto max-w-5xl px-6 pt-8">
        <StrapiImage
          class="w-full h-72 sm:h-96 object-cover rounded-2xl"
          src={featuredImage.url}
          alt={featuredImage?.alternativeText}
          height={600}
          width={1200}
        />
      </div>
    )}

    <div class="mx-auto max-w-3xl px-6 py-12 text-center">
      {contentTags && contentTags.length > 0 && (
        <div class="mb-4 flex flex-wrap justify-center gap-2">
          {contentTags.map((tag: any) => (
            <span class="rounded-full bg-primary-50 px-3 py-1 text-xs font-semibold text-primary-700">
              {tag.title}
            </span>
          ))}
        </div>
      )}

      <h1 class="text-3xl font-bold tracking-tight text-secondary sm:text-4xl lg:text-5xl font-heading">
        {title}
      </h1>

      {author && (
        <div class="mt-6 flex items-center justify-center gap-3">
          {author.image && (
            <StrapiImage
              src={author.image.url}
              alt={author.image.alternativeText}
              height={48}
              width={48}
              class="h-10 w-10 rounded-full object-cover"
            />
          )}
          <div class="text-left">
            <p class="text-sm font-semibold text-secondary">{author.fullName}</p>
            <p class="text-xs text-faint">Author</p>
          </div>
        </div>
      )}
    </div>

    {content && <Markdown data={{ content: content, __component: "blocks.markdown" }} />}
  </article>
  <BlockRenderer blocks={blocks} />
</BaseLayout>
