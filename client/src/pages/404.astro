---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="flex items-center justify-center py-32">
    <div class="mx-auto max-w-md px-6 text-center">
      <p class="text-6xl font-bold text-primary-600 font-heading">404</p>
      <h1 class="mt-4 text-2xl font-bold text-secondary">Page not found</h1>
      <p class="mt-2 text-muted">Sorry, we couldn't find the page you're looking for.</p>
      <a
        class="mt-8 inline-flex items-center rounded-button bg-primary-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-primary-700 transition"
        href="/"
      >
        Back to homepage
      </a>
    </div>
  </section>
</BaseLayout>
