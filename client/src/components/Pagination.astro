---
export type NumericalString = `${number}`
export type RouteString = string | null | undefined

interface Props {
  previousPage?: RouteString
  nextPage?: RouteString
  currentPage: number
  totalPages: number
  class?: string
  ariaLabel?: string
}

const {
  previousPage = '#',
  nextPage = '#',
  currentPage = 1,
  totalPages = 12,
  class: className,
  ariaLabel = 'Pagination',
} = Astro.props
---

<nav class:list={['flex items-center justify-center gap-2', className]} aria-label={ariaLabel}>
  <a
    href={previousPage}
    aria-label={`Go to previous page (page ${currentPage - 1})`}
    aria-disabled={currentPage === 1}
    class={`inline-flex items-center justify-center rounded-button border p-2 transition ${
      currentPage === 1
        ? 'border-border text-faint cursor-not-allowed pointer-events-none'
        : 'border-border text-muted hover:border-border-hover hover:text-secondary'
    }`}
  >
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </a>

  <span class="px-3 text-sm text-muted">
    Page <span class="font-semibold text-secondary">{currentPage}</span> of {totalPages}
  </span>

  <a
    href={nextPage}
    aria-label={`Go to next page (page ${currentPage + 1})`}
    aria-disabled={currentPage === totalPages}
    class={`inline-flex items-center justify-center rounded-button border p-2 transition ${
      currentPage === totalPages
        ? 'border-border text-faint cursor-not-allowed pointer-events-none'
        : 'border-border text-muted hover:border-border-hover hover:text-secondary'
    }`}
  >
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </a>
</nav>
