---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<li class="rounded-card border border-border bg-surface-raised faq-item transition hover:border-border-hover">
  <button class="flex w-full items-center justify-between gap-4 p-5 text-left faq-item-button">
    <span class="text-base font-semibold text-secondary font-heading">{question}</span>
    <svg
      class="h-5 w-5 shrink-0 text-muted transition-transform duration-200 faq-icon"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  <div class="hidden px-5 pb-5 faq-item-answer">
    <p class="text-sm leading-relaxed text-muted">{answer}</p>
  </div>
</li>

<style>
  .faq-item-button { cursor: pointer; }
  .faq-icon.rotate-180 { transform: rotate(180deg); }
</style>

<script>
  const faqItems = document.querySelectorAll('.faq-item');

  faqItems.forEach(faqItem => {
    const faqItemButton = faqItem.querySelector('.faq-item-button') as HTMLButtonElement;
    const faqItemAnswer = faqItem.querySelector('.faq-item-answer') as HTMLDivElement;
    const faqIcon = faqItem.querySelector('.faq-icon') as SVGElement;

    faqItemButton.addEventListener('click', () => {
      faqItemAnswer.classList.toggle('hidden');
      faqIcon.classList.toggle('rotate-180');
    });
  });
</script>
