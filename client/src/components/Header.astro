---
import type { GlobalPageHeader } from "../utils/types";
import StrapiImage from "./StrapiImage.astro";

interface Props {
  data: GlobalPageHeader;
}

const {
  data: { logo, navItems, cta },
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-border bg-surface-raised/80 backdrop-blur-lg">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a class="flex items-center gap-2 font-heading text-lg font-bold tracking-tight" href={logo.logoLink}>
      <StrapiImage src={logo.image.url} alt={logo.image.alternativeText} height={36} width={36} class="rounded-lg" />
    </a>

    <button class="lg:hidden rounded-lg p-2 text-muted hover:text-secondary transition" id="burger-button" aria-label="Toggle menu">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <ul class="hidden lg:flex items-center gap-1">
      {navItems.map((item) => (
        <li>
          <a
            class={`rounded-lg px-3 py-2 text-sm font-medium transition ${
              currentPath === item.href
                ? 'bg-primary-50 text-primary-700'
                : 'text-muted hover:text-secondary hover:bg-surface-alt'
            }`}
            href={item.href}
            target={item.isExternal ? "_blank" : "_self"}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    {cta && (
      <a
        class="hidden lg:inline-flex items-center rounded-button bg-primary-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-primary-700 transition"
        href={cta.href}
        target={cta.isExternal ? "_blank" : "_self"}
      >
        {cta.label}
      </a>
    )}
  </nav>

  <!-- Mobile menu -->
  <div class="navbar-menu fixed inset-0 z-50 hidden" id="navbar-menu">
    <div class="navbar-backdrop fixed inset-0 bg-black/20 backdrop-blur-sm"></div>
    <nav class="relative ml-auto flex h-full w-80 max-w-[85vw] flex-col bg-surface-raised p-6 shadow-xl">
      <div class="mb-8 flex items-center justify-between">
        <a class="flex items-center gap-2 font-heading text-lg font-bold" href={logo.logoLink}>
          <StrapiImage src={logo.image.url} alt={logo.image.alternativeText} height={36} width={36} class="rounded-lg" />
        </a>
        <button class="navbar-close rounded-lg p-2 text-muted hover:text-secondary transition" aria-label="Close menu">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <ul class="flex-1 space-y-1">
        {navItems.map((item) => (
          <li>
            <a
              class={`block rounded-lg px-4 py-2.5 text-sm font-medium transition ${
                currentPath === item.href
                  ? 'bg-primary-50 text-primary-700'
                  : 'text-muted hover:bg-surface-alt hover:text-secondary'
              }`}
              href={item.href}
              target={item.isExternal ? "_blank" : "_self"}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      {cta && (
        <a
          class="mt-6 block rounded-button bg-primary-600 px-4 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-primary-700 transition"
          href={cta.href}
          target={cta.isExternal ? "_blank" : "_self"}
        >{cta.label}</a>
      )}
    </nav>
  </div>
</header>

<script>
  const burgerButton = document.getElementById('burger-button') as HTMLButtonElement;
  const navbarMenu = document.getElementById('navbar-menu') as HTMLDivElement;
  const closeButton = document.querySelector('.navbar-close') as HTMLButtonElement;
  const backdrop = document.querySelector('.navbar-backdrop') as HTMLDivElement;

  burgerButton.addEventListener('click', () => navbarMenu.classList.toggle('hidden'));
  closeButton.addEventListener('click', () => navbarMenu.classList.add('hidden'));
  backdrop.addEventListener('click', () => navbarMenu.classList.add('hidden'));
</script>
