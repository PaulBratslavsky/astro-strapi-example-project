---
import type { ContentWithImageProps } from "../../utils/types";
import StrapiImage from "../StrapiImage.astro";
interface Props {
  data: ContentWithImageProps;
}

const {
  data: { heading, text, image, link, reversed },
} = Astro.props;
---

<section>
  <div class="mx-auto max-w-6xl px-6 py-20">
    <div class={`flex flex-col items-center gap-10 lg:gap-16 ${reversed ? 'lg:flex-row-reverse' : 'lg:flex-row'}`}>
      <div class="w-full lg:w-1/2">
        <StrapiImage
          src={image.url}
          alt={image.alternativeText}
          height={600}
          width={800}
          class="w-full rounded-2xl object-cover shadow-sm"
        />
      </div>
      <div class="w-full lg:w-1/2">
        <h2 class="text-2xl font-bold tracking-tight text-secondary sm:text-3xl font-heading">{heading}</h2>
        <p class="mt-4 leading-relaxed text-muted">{text}</p>
        {link && (
          <a
            class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-primary-600 hover:text-primary-700 transition"
            href={link.href}
            target={link.isExternal ? '_blank' : '_self'}
          >
            {link.label}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        )}
      </div>
    </div>
  </div>
</section>
