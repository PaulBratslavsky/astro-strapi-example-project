---
import type { CardGridProps } from "../../utils/types";

interface Props {
  data: CardGridProps;
}

const {
  data: { card },
} = Astro.props;
---

<section>
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {card && card.map((card) => (
        <div class="rounded-card border border-border bg-surface-raised p-6 transition hover:shadow-md hover:border-border-hover">
          <h4 class="text-lg font-semibold text-secondary font-heading">{card.heading}</h4>
          <p class="mt-2 text-sm leading-relaxed text-muted">{card.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
